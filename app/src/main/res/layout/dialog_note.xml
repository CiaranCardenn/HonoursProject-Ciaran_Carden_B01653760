<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@color/background_beige">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title field - white background -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputStyle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/title_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Title"
                android:textColor="@color/text_dark"
                android:background="@color/pure_white"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Content field - white background -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/CustomTextInputStyle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/content_input"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:hint="Content"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:textColor="@color/text_dark"
                android:background="@color/pure_white"/>
        </com.google.android.material.textfield.TextInputLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@color/pure_white"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_edit"
                android:padding="8dp"
                app:tint="@color/dark_beige" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_dialog_map"
                android:padding="8dp"
                app:tint="@color/dark_beige" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:padding="8dp"
                app:tint="@color/dark_beige" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/encrypt_check"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Encrypt this note"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="16dp"
            android:buttonTint="@color/dark_beige"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Self-destruct timer:"
            android:textSize="16sp"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/time_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/pure_white"
            android:padding="8dp"
            android:dropDownSelector="@color/dark_beige"/>
    </LinearLayout>
</ScrollView>